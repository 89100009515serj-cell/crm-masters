generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN     // Управляющий
  CURATOR   // Куратор
  MANAGER   // Менеджер
  MASTER    // Мастер
}

enum RequestStatus {
  NEW
  ASSIGNED
  ACCEPTED      // "Принял"
  ON_SITE       // "На адресе"
  COMPLETED
  CANCELLED
}

enum NotificationChannel {
  IN_APP
  TELEGRAM
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  phone        String
  email        String?  @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  telegramChatId String?
  telegramEnabled Boolean @default(false)
  telegramNotifyTypes String[] @default(["ASSIGNED", "RESCHEDULE", "ACCEPTED", "ON_SITE"])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requestsCreated  Request[]       @relation("CreatedBy")
  requestsAssigned Request[]       @relation("AssignedMaster")
  reschedules      RescheduleLog[]
  notifications    Notification[]

  @@index([role])
}

model ServiceType {
  id       String    @id @default(cuid())
  name     String    @unique
  isActive Boolean   @default(true)
  requests Request[]
}

model Source {
  id       String    @id @default(cuid())
  name     String    @unique
  requests Request[]
}

model Request {
  id            String        @id @default(cuid())
  sourceId      String
  source        Source        @relation(fields: [sourceId], references: [id])

  clientName    String
  clientPhone   String
  clientAddress String
  description   String

  serviceTypeId String
  serviceType   ServiceType   @relation(fields: [serviceTypeId], references: [id])

  scheduledAt   DateTime
  actualStartAt DateTime?
  completedAt   DateTime?

  status RequestStatus @default(NEW)

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  assignedMasterId String?
  assignedMaster   User?   @relation("AssignedMaster", fields: [assignedMasterId], references: [id])

  totalReceipt    Decimal? @db.Decimal(10, 2)
  expense         Decimal? @db.Decimal(10, 2)
  comment         String?
  receiptPhotoUrls String[] @default([])

  netReceipt    Decimal? @db.Decimal(10, 2)
  masterPayout  Decimal? @db.Decimal(10, 2)
  managerPayout Decimal? @db.Decimal(10, 2)
  curatorPayout Decimal? @db.Decimal(10, 2)
  companyProfit Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reschedules   RescheduleLog[]
  notifications Notification[]

  @@index([status])
  @@index([scheduledAt])
  @@index([assignedMasterId])
  @@index([serviceTypeId])
  @@index([sourceId])
  @@index([clientName])
  @@index([clientPhone])
  @@index([clientAddress])
}

model RescheduleLog {
  id    String  @id @default(cuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id])

  oldScheduledAt DateTime
  newScheduledAt DateTime
  reason         String?

  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  createdAt DateTime @default(now())

  @@index([requestId])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  requestId String?
  request   Request?            @relation(fields: [requestId], references: [id])

  channel   NotificationChannel @default(IN_APP)
  type      String
  message   String
  isRead    Boolean             @default(false)
  deliveredToTelegram Boolean   @default(false)
  createdAt DateTime            @default(now())

  @@index([userId, isRead])
}
